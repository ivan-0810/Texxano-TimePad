{
  "expo": {
    "name": "Texxano",
    "slug": "texxanoApp",
    "scheme": "texxano",
    "version": "1.4.6",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/ce467646-37bb-438e-adb6-94492f953808",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "ios": {
      "supportsTablet": true,
      "buildNumber": "60",
      "bundleIdentifier": "texxano.v1.ios",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Location permission is needed in order to track and log device location!",
        "NSLocationAlwaysUsageDescription": "Location permission is required for background location tracking.",
        "NSCameraUsageDescription": "We need access to your camera to take photos.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location even in the background to track your position continuously.",
        "UIBackgroundModes": [
          "location",
          "remote-notification",
          "location",
          "remote-notification"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "googleMapsApiKey": "AIzaSyABE6JpKxJ0BHt_qJ1p9rAVusRmhBvzQ58"
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "versionCode": 64,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "FOREGROUND_SERVICE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.WAKE_LOCK",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyABE6JpKxJ0BHt_qJ1p9rAVusRmhBvzQ58"
        },
        "supports16kbPages": true
      },
      "package": "texxano.v1.android",
      "googleServicesFile": "./google-services.json",
      "runtimeVersion": "1.0.0",
      "compileSdkVersion": 35,
      "targetSdkVersion": 35,
      "minSdkVersion": 24
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-file-system",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff",
          "sounds": [
            "./assets/notification.mp3"
          ]
        }
      ],
      [
        "react-native-document-scanner-plugin",
        {
          "cameraPermission": "We need camera access, so you can scan documents"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0",
            "ndkVersion": "27.0.12077987",
            "enable16KbPageSize": true
          }
        }
      ]
    ],
    "userInterfaceStyle": "automatic",
    "extra": {
      "eas": {
        "projectId": "ce467646-37bb-438e-adb6-94492f953808"
      }
    }
  }
}
